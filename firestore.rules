// firestore.rules
// Upload this in Firebase Console → Firestore → Rules tab

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users collection ──────────────────────────────────
    // Users can only read and write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;

      // ── Captions subcollection ───────────────────────
      match /captions/{captionId} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;
      }
    }

    // ── App config (admin sets, users only read) ──────────
    match /app_config/{document} {
      allow read:  if request.auth != null;
      allow write: if false;  // Only via Firebase Console
    }
  }
}
